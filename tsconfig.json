{
  "compilerOptions": {
    "types": ["node"],
    "target": "es2022",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "noImplicitAny": false,
    "paths": {
      "@/lib/fetch": ["apps/frontend/lib/fetch/index.ts"],
      "@/lib/fetch/*": ["apps/frontend/lib/fetch/*"],
      "@/lib/savefile": ["apps/frontend/lib/savefile.ts"],
      "@/lib/resizeImage": ["apps/frontend/lib/resizeImage.ts"],
      "@/lib/dnd": ["apps/frontend/lib/dnd.ts"],
      "@/lib/codeblock": ["apps/frontend/lib/codeblock.ts"],
      "@/lib/version": ["apps/frontend/lib/version.ts"],
      "@/frontend/*": ["apps/frontend/*"],
      "@/lib/mimeTypes": ["apps/frontend/lib/mimeTypes.ts"],
      "@/lib/const": ["apps/frontend/lib/const.ts"],
      "@/lib/logging": ["apps/backend/lib/logging.ts"],
      "@/lib/routes": ["apps/backend/lib/routes.ts"],
      "@/lib/auth": ["apps/backend/lib/auth/password.ts"],
      "@/lib/auth/*": ["apps/backend/lib/auth/*"],
      "@/lib/models": ["apps/backend/lib/models.ts"],
      "@/lib/parameters": ["apps/backend/lib/parameters.ts"],
      "@/lib/properties": ["apps/backend/lib/properties.ts"],
      "@/lib/provision": ["apps/backend/lib/provision.ts"],
      "@/lib/provision_schema": ["apps/backend/lib/provision_schema.ts"],
      "@/lib/uris": ["apps/backend/lib/uris.ts"],
      "@/lib/file-analysis": ["apps/backend/lib/file-analysis/index.ts"],
      "@/lib/file-analysis/*": ["apps/backend/lib/file-analysis/*"],
      "@/lib/MessageAuditor": ["apps/backend/lib/MessageAuditor.ts"],
      "@/lib/satellite/*": ["apps/backend/lib/satellite/*"],
      "@/lib/userSecrets": ["apps/backend/lib/userSecrets.ts"],
      "@/lib/userSecretMessages": ["apps/backend/lib/userSecretMessages.ts"],
      "@/lib/chat/litellm": ["apps/backend/lib/chat/litellm/index.ts"],
      "@/lib/chat/litellm/*": ["apps/backend/lib/chat/litellm/*"],
      "@/lib/chat/models": ["packages/core/src/models/index.ts"],
      "@/lib/chat/models/*": ["packages/core/src/models/*"],
      "@/lib/storage": ["apps/backend/lib/storage/index.ts"],
      "@/lib/storage/*": ["apps/backend/lib/storage/*"],
      "@/lib/textextraction": ["apps/backend/lib/textextraction/index.ts"],
      "@/lib/textextraction/*": ["apps/backend/lib/textextraction/*"],
      "@/lib/vendor/*": ["apps/backend/lib/vendor/*"],
      "@/lib/http/*": ["apps/backend/lib/http/*"],
      "@/lib/tracing/*": ["apps/backend/lib/tracing/*"],
      "@/lib/backend/*": ["apps/backend/lib/backend/*"],
      "@/lib/*": ["packages/core/src/*"],
      "@/components/*": ["apps/frontend/components/*"],
      "@/services/*": ["apps/frontend/services/*"],
      "@/utils/*": ["utils/*"],
      "@/hooks/*": ["apps/frontend/hooks/*"],
      "@/types/*": ["packages/core/src/types/*"],
      "@/pages/*": ["apps/frontend/pages/*"],
      "@/models/*": ["apps/backend/models/*"],
      "@/app/api/*": ["apps/backend/api/*"],
      "@/app/*": ["apps/frontend/app/*"],
      "@/api/*": ["apps/backend/api/*"],
      "@/backend/*": ["apps/backend/*"],
      "@/ee/*": ["apps/backend/ee/*"],
      "@/db/*": ["apps/backend/db/*"],
      "@/context/*": ["apps/frontend/context/*"],
      "lib/fetch": ["apps/frontend/lib/fetch/index.ts"],
      "lib/fetch/*": ["apps/frontend/lib/fetch/*"],
      "lib/savefile": ["apps/frontend/lib/savefile.ts"],
      "lib/resizeImage": ["apps/frontend/lib/resizeImage.ts"],
      "lib/dnd": ["apps/frontend/lib/dnd.ts"],
      "lib/codeblock": ["apps/frontend/lib/codeblock.ts"],
      "lib/version": ["apps/frontend/lib/version.ts"],
      "frontend/*": ["apps/frontend/*"],
      "lib/mimeTypes": ["apps/frontend/lib/mimeTypes.ts"],
      "lib/const": ["apps/frontend/lib/const.ts"],
      "lib/logging": ["apps/backend/lib/logging.ts"],
      "lib/routes": ["apps/backend/lib/routes.ts"],
      "lib/auth": ["apps/backend/lib/auth/password.ts"],
      "lib/auth/*": ["apps/backend/lib/auth/*"],
      "lib/models": ["apps/backend/lib/models.ts"],
      "lib/parameters": ["apps/backend/lib/parameters.ts"],
      "lib/properties": ["apps/backend/lib/properties.ts"],
      "lib/provision": ["apps/backend/lib/provision.ts"],
      "lib/provision_schema": ["apps/backend/lib/provision_schema.ts"],
      "lib/uris": ["apps/backend/lib/uris.ts"],
      "lib/file-analysis": ["apps/backend/lib/file-analysis/index.ts"],
      "lib/file-analysis/*": ["apps/backend/lib/file-analysis/*"],
      "lib/MessageAuditor": ["apps/backend/lib/MessageAuditor.ts"],
      "lib/satellite/*": ["apps/backend/lib/satellite/*"],
      "lib/userSecrets": ["apps/backend/lib/userSecrets.ts"],
      "lib/userSecretMessages": ["apps/backend/lib/userSecretMessages.ts"],
      "lib/chat/litellm/*": ["apps/backend/lib/chat/litellm/*"],
      "lib/chat/models": ["packages/core/src/models/index.ts"],
      "lib/chat/models/*": ["packages/core/src/models/*"],
      "lib/storage": ["apps/backend/lib/storage/index.ts"],
      "lib/storage/*": ["apps/backend/lib/storage/*"],
      "lib/textextraction": ["apps/backend/lib/textextraction/index.ts"],
      "lib/textextraction/*": ["apps/backend/lib/textextraction/*"],
      "lib/vendor/*": ["apps/backend/lib/vendor/*"],
      "lib/http/*": ["apps/backend/lib/http/*"],
      "lib/tracing/*": ["apps/backend/lib/tracing/*"],
      "lib/backend/*": ["apps/backend/lib/backend/*"],
      "lib/*": ["packages/core/src/*"],
      "models/*": ["apps/backend/models/*"],
      "db/*": ["apps/backend/db/*"],
      "types/*": ["packages/core/src/types/*"],
      "components/*": ["apps/frontend/components/*"],
      "services/*": ["apps/frontend/services/*"],
      "hooks/*": ["apps/frontend/hooks/*"],
      "pages/*": ["apps/frontend/pages/*"],
      "app/*": ["apps/frontend/app/*"],
      "backend/*": ["apps/backend/*"],
      "ee/*": ["apps/backend/ee/*"],
      "templates": ["apps/backend/lib/templates.ts"],
      "@logicle/file-analyzer": ["packages/file-analyzer/src/index.ts"],
      "@logicle/file-analyzer/analyzers": ["packages/file-analyzer/src/analyzers.ts"],
      "@logicle/file-analyzer/worker": ["packages/file-analyzer/src/worker/runtime.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "apps/frontend/i18next-extend.d.ts",
    "apps/frontend/next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "next-auth.d.ts",
    "apps/backend/server.ts"
  ],
  "exclude": ["node_modules"]
}
