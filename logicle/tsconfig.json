{
  "compilerOptions": {
    "types": ["node"],
    "target": "es2022",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "noImplicitAny": false,
    "paths": {
      "@/lib/*": ["packages/core/src/lib/*"],
      "@/components/*": ["apps/frontend/components/*"],
      "@/services/*": ["apps/frontend/services/*"],
      "@/utils/*": ["utils/*"],
      "@/hooks/*": ["apps/frontend/hooks/*"],
      "@/types/*": ["packages/core/src/types/*"],
      "@/pages/*": ["apps/frontend/pages/*"],
      "@/models/*": ["packages/core/src/models/*"],
      "@/app/api/*": ["apps/backend/backend/api/*"],
      "@/app/*": ["apps/frontend/app/*"],
      "@/api/*": ["apps/backend/backend/api/*"],
      "@/backend/*": ["apps/backend/backend/*"],
      "@/db/*": ["packages/core/src/db/*"],
      "@/context/*": ["apps/frontend/context/*"],
      "@/ee/*": ["packages/core/src/ee/*"],
      "lib/*": ["packages/core/src/lib/*"],
      "models/*": ["packages/core/src/models/*"],
      "db/*": ["packages/core/src/db/*"],
      "types/*": ["packages/core/src/types/*"],
      "ee/*": ["packages/core/src/ee/*"],
      "components/*": ["apps/frontend/components/*"],
      "services/*": ["apps/frontend/services/*"],
      "hooks/*": ["apps/frontend/hooks/*"],
      "pages/*": ["apps/frontend/pages/*"],
      "app/*": ["apps/frontend/app/*"],
      "backend/*": ["apps/backend/backend/*"],
      "templates": ["packages/core/src/templates.ts"],
      "@logicle/file-analyzer": ["packages/file-analyzer/src/index.ts"],
      "@logicle/file-analyzer/analyzers": ["packages/file-analyzer/src/analyzers.ts"],
      "@logicle/file-analyzer/worker": ["packages/file-analyzer/src/worker/runtime.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "apps/frontend/i18next-extend.d.ts",
    "apps/frontend/next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "next-auth.d.ts",
    "packages/core/src/lib/satelliteHub.ts",
    "apps/backend/server.ts"
  ],
  "exclude": ["node_modules"]
}
